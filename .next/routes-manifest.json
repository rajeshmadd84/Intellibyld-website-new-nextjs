      "routeKeys": {},
      "namedRegex": "^/digital\\-twins(?:/)?$"
    },
    {
      "page": "/faqs",
      "regex": "^/faqs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faqs(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/home-1",
      "regex": "^/home\\-1(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/home\\-1(?:/)?$"
    },
    {
      "page": "/home-2",
      "regex": "^/home\\-2(?:/)?$",
      "routeKeys": {},
