    {
      "page": "/price",
      "regex": "^/price(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/price(?:/)?$"
    },
    {
      "page": "/shop",
      "regex": "^/shop(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/shop(?:/)?$"
    },
    {
      "page": "/sustainability",
      "regex": "^/sustainability(?:/)?$",
