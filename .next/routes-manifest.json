      "routeKeys": {},
      "namedRegex": "^/agentic\\-ai(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/contact-us",
      "regex": "^/contact\\-us(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact\\-us(?:/)?$"
    },
    {
      "page": "/digital-twins",
